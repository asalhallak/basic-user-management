# Normalize line endings to match .editorconfig (LF).
* text=auto eol=lf

# Shell scripts must stay LF for shebangs and CI.
*.sh text eol=lf

# Windows batch files keep CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary assets — do not modify.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
